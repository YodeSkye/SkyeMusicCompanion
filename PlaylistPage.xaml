<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SkyeMusicCompanion.PlaylistPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:d="http://schemas.microsoft.com/dotnet/2021/maui/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:SkyeMusicCompanion.Models"
    mc:Ignorable="d"
    x:DataType="x:Object"
    Title="Playlist">

    <Grid RowDefinitions="Auto,*">

        <!-- Toast overlay layer -->
        <Grid x:Name="ToastLayer"
          Grid.RowSpan="2"
          InputTransparent="True" />

        <!-- Search bar -->
        <SearchBar x:Name="SearchBox"
               Grid.Row="0"
               Placeholder="Search"
               TextChanged="OnSearchTextChanged" />

        <!-- Playlist -->
        <CollectionView x:Name="PlaylistView"
                    Grid.Row="1"
                    SelectionMode="None">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PlaylistItem">
                    <Grid Padding="10" BackgroundColor="Transparent">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                            Tapped="OnItemTapped"
                            CommandParameter="{Binding}" />
                        </Grid.GestureRecognizers>

                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid"
                                     Binding="{Binding IsCurrent}"
                                     Value="True">
                                <Setter Property="BackgroundColor" Value="#DDEBFF" />
                            </DataTrigger>
                        </Grid.Triggers>

                        <Label Text="{Binding Title}"
                           FontSize="16">

                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                         Binding="{Binding IsCurrent}"
                                         Value="True">
                                    <Setter Property="FontAttributes" Value="Bold" />
                                </DataTrigger>

                                <DataTrigger TargetType="Label"
                                         Binding="{Binding IsCurrent}"
                                         Value="True">
                                    <Setter Property="TextColor" Value="#8b1a10" />
                                </DataTrigger>
                            </Label.Triggers>

                        </Label>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>