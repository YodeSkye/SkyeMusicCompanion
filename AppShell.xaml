<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SkyeMusicCompanion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SkyeMusicCompanion"
    Title="SkyeMusicCompanion"
    Shell.FlyoutBehavior="Flyout">

    <!-- Home -->
    <FlyoutItem Title="Home" Route="MainPage" Icon="app.png">
        <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
    </FlyoutItem>

    <!-- Reconnect (hidden by default) -->
    <FlyoutItem
        x:Name="ReconnectItem"
        Title="Reconnect"
        Route="ReconnectRoute"
        Icon="reconnect.png"
        IsVisible="False">
        <ShellContent>
            <ContentPage />
        </ShellContent>
    </FlyoutItem>

    <!-- Playlist -->
    <FlyoutItem Title="Playlist" Route="PlaylistPage" Icon="playlist.png">
        <ShellContent ContentTemplate="{DataTemplate local:PlaylistPage}" />
    </FlyoutItem>

    <!-- View Log -->
    <FlyoutItem Title="View Log" Route="LogPage" Icon="log.png">
        <ShellContent ContentTemplate="{DataTemplate local:LogPage}" />
    </FlyoutItem>

    <!-- Settings -->
    <FlyoutItem Title="Settings" Route="SettingsPage" Icon="settings.png">
        <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
    </FlyoutItem>

</Shell>