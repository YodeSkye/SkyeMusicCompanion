<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SkyeMusicCompanion.LogPage">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20">

        <Button Grid.Row="0"
                Text="Clear Log"
                BackgroundColor="#8b1a10"
                Clicked="OnClearLogClicked"
                Margin="0,0,0,5" />

        <Button Grid.Row="1"
                Text="Save Log As..."
                BackgroundColor="#8b1a10"
                Clicked="OnSaveLogClicked"
                Margin="0,0,0,40" />

        <CollectionView x:Name="LogList"
                Grid.Row="2"
                ItemsSource="{Binding LogLines}"
                SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Label Text="{Binding}"
                   FontFamily="monospace"
                   FontSize="14" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
